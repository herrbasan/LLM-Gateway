#!/bin/sh
# Pre-commit hook to prevent committing sensitive files
# Install: git config core.hooksPath .git-hooks

# Get list of staged files
STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACM)

VIOLATIONS=""

for FILE in $STAGED_FILES; do
    # Check for backup files
    if echo "$FILE" | grep -q "config.json.backup-"; then
        VIOLATIONS="$VIOLATIONS\n  - $FILE (backup file - should be in .gitignore)"
    fi
    
    # Check for .env files
    if echo "$FILE" | grep -qE '^\.env|^\.env\.'; then
        VIOLATIONS="$VIOLATIONS\n  - $FILE (environment file - contains secrets)"
    fi
    
    # Check for PEM/KEY files
    if echo "$FILE" | grep -qE '\.(pem|key|p12|pfx)$'; then
        VIOLATIONS="$VIOLATIONS\n  - $FILE (cryptographic key)"
    fi
done

if [ -n "$VIOLATIONS" ]; then
    echo "ERROR: Attempting to commit sensitive files:"
    echo -e "$VIOLATIONS"
    echo ""
    echo "To bypass this check (not recommended):"
    echo "  git commit --no-verify"
    echo ""
    echo "To fix:"
    echo "  1. git reset HEAD <file>  (unstage the file)"
    echo "  2. Add to .gitignore if it shouldn't be tracked"
    echo "  3. git add .gitignore && git commit"
    exit 1
fi

exit 0
