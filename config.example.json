{
  "port": 3400,
  "host": "0.0.0.0",
  
  "models": {
    "_comment": "=== LLM GATEWAY MODEL CONFIGURATION ===",
    
    "_comment_lmstudio": "--- LM Studio (External Server) ---",
    "lmstudio-chat": {
      "type": "chat",
      "adapter": "lmstudio",
      "endpoint": "http://localhost:12345",
      "adapterModel": "qwen/qwen2.5-9b",
      "capabilities": {
        "contextWindow": 30000,
        "vision": true,
        "structuredOutput": true,
        "streaming": true
      }
    },
    "lmstudio-embed": {
      "type": "embedding",
      "adapter": "lmstudio",
      "endpoint": "http://localhost:12345",
      "adapterModel": "text-embedding-nomic",
      "capabilities": {
        "contextWindow": 512,
        "dimensions": 768
      }
    },
    
    "_comment_llamacpp": "--- llama.cpp (llama-cpp-gateway Manager) ---",
    "_comment_llamacpp_note": "Start manager first: node D:\\DEV\\llama-cpp-gateway\\src\\manager\\server.js",
    
    "llama-chat": {
      "type": "chat",
      "adapter": "llamacpp",
      "endpoint": "http://localhost:4080",
      "maxTokens": 8192,
      "hardTokenCap": 10000,
      "capabilities": {
        "contextWindow": 64000,
        "vision": true,
        "streaming": true,
        "structuredOutput": true
      },
      "imageInputLimit": {
        "maxDimension": 2048,
        "maxFileSize": 52428800,
        "supportedFormats": ["png", "jpeg", "gif", "webp"]
      },
      "localInference": {
        "enabled": true,
        "modelPath": "D:/models/chat-model.gguf",
        "mmproj": "D:/models/mmproj-f16.gguf",
        "contextSize": 64000,
        "gpuLayers": 99,
        "flashAttention": true,
        "mlock": true
      }
    },
    
    "llama-embed": {
      "type": "embedding",
      "adapter": "llamacpp",
      "endpoint": "http://localhost:4080",
      "capabilities": {
        "contextWindow": 512,
        "dimensions": 1024
      },
      "localInference": {
        "enabled": true,
        "modelPath": "D:/models/embedding-model.gguf",
        "contextSize": 512,
        "gpuLayers": 99,
        "embedding": true,
        "pooling": "mean",
        "batchSize": 512,
        "mlock": true
      }
    },
    
    "_comment_ollama": "--- Ollama ---",
    "ollama-chat": {
      "type": "chat",
      "adapter": "ollama",
      "endpoint": "http://localhost:11434",
      "adapterModel": "gemma3:12b",
      "capabilities": {
        "contextWindow": 8192,
        "vision": true,
        "structuredOutput": true,
        "streaming": true
      }
    },
    "ollama-embed": {
      "type": "embedding",
      "adapter": "ollama",
      "endpoint": "http://localhost:11434",
      "adapterModel": "nomic-embed-text",
      "capabilities": {
        "contextWindow": 512,
        "dimensions": 768
      }
    },
    
    "_comment_gemini": "--- Google Gemini ---",
    "gemini-flash": {
      "type": "chat",
      "adapter": "gemini",
      "endpoint": "https://generativelanguage.googleapis.com/v1beta",
      "apiKey": "your-gemini-api-key",
      "adapterModel": "gemini-2.0-flash",
      "capabilities": {
        "contextWindow": 1000000,
        "vision": true,
        "structuredOutput": "json_schema",
        "streaming": true
      }
    },
    "gemini-embedding": {
      "type": "embedding",
      "adapter": "gemini",
      "endpoint": "https://generativelanguage.googleapis.com/v1beta",
      "apiKey": "your-gemini-api-key",
      "adapterModel": "embedding-001",
      "capabilities": {
        "contextWindow": 2048,
        "dimensions": 768
      }
    },
    "gemini-image": {
      "type": "image",
      "adapter": "gemini",
      "endpoint": "https://generativelanguage.googleapis.com/v1beta",
      "apiKey": "your-gemini-api-key",
      "adapterModel": "imagen-4.0-generate-001",
      "capabilities": {
        "maxResolution": "2048x2048",
        "supportedFormats": ["png", "jpeg", "webp"]
      }
    },
    "gemini-tts": {
      "type": "audio",
      "adapter": "gemini",
      "endpoint": "https://generativelanguage.googleapis.com/v1beta",
      "apiKey": "your-gemini-api-key",
      "adapterModel": "gemini-2.5-pro-preview-tts",
      "capabilities": {
        "tts": true,
        "maxDuration": 600,
        "supportedFormats": ["mp3", "wav", "pcm"]
      }
    },
    
    "_comment_openai": "--- OpenAI ---",
    "openai-chat": {
      "type": "chat",
      "adapter": "openai",
      "endpoint": "https://api.openai.com/v1",
      "apiKey": "your-openai-api-key",
      "adapterModel": "gpt-4o",
      "capabilities": {
        "contextWindow": 128000,
        "vision": true,
        "structuredOutput": true,
        "streaming": true
      }
    },
    "openai-image": {
      "type": "image",
      "adapter": "openai",
      "endpoint": "https://api.openai.com/v1",
      "apiKey": "your-openai-api-key",
      "adapterModel": "dall-e-3",
      "capabilities": {
        "maxResolution": "1024x1024",
        "supportedFormats": ["png", "jpeg"]
      }
    },
    "openai-tts": {
      "type": "audio",
      "adapter": "openai",
      "endpoint": "https://api.openai.com/v1",
      "apiKey": "your-openai-api-key",
      "adapterModel": "tts-1",
      "capabilities": {
        "streaming": false
      }
    },
    "openai-responses": {
      "type": "chat",
      "adapter": "responses",
      "endpoint": "https://api.openai.com/v1",
      "apiKey": "your-openai-api-key",
      "adapterModel": "gpt-4o",
      "maxTokens": 4096,
      "capabilities": {
        "contextWindow": 128000,
        "vision": true,
        "streaming": true,
        "tools": true,
        "stateful": true
      }
    },
    
    "_comment_grok": "--- xAI Grok ---",
    "grok-chat": {
      "type": "chat",
      "adapter": "openai",
      "endpoint": "https://api.x.ai/v1",
      "apiKey": "your-grok-api-key",
      "adapterModel": "grok-2",
      "capabilities": {
        "contextWindow": 1000000,
        "vision": true,
        "structuredOutput": true,
        "streaming": true
      }
    },
    
    "_comment_anthropic": "--- Anthropic Claude ---",
    "anthropic-chat": {
      "type": "chat",
      "adapter": "anthropic",
      "endpoint": "https://api.anthropic.com/v1",
      "apiKey": "your-anthropic-api-key",
      "adapterModel": "claude-3-5-sonnet-20241022",
      "capabilities": {
        "contextWindow": 200000,
        "vision": true,
        "streaming": true,
        "structuredOutput": true
      }
    },
    
    "_comment_kimi": "--- Moonshot Kimi ---",
    "kimi-chat": {
      "type": "chat",
      "adapter": "kimi",
      "endpoint": "https://api.kimi.com/coding/v1",
      "apiKey": "your-kimi-api-key",
      "adapterModel": "kimi-for-coding",
      "capabilities": {
        "contextWindow": 256000,
        "vision": true,
        "structuredOutput": true,
        "streaming": true
      }
    },
    
    "_comment_alibaba": "--- Alibaba Cloud (DashScope) ---",
    "alibaba-chat": {
      "type": "chat",
      "adapter": "alibaba",
      "endpoint": "https://coding-intl.dashscope.aliyuncs.com/v1",
      "apiKey": "your-dashscope-api-key",
      "adapterModel": "qwen3.5-plus",
      "capabilities": {
        "contextWindow": 1000000,
        "maxOutputTokens": 65536,
        "vision": true,
        "structuredOutput": true,
        "streaming": true
      }
    },
    
    "_comment_dashscope_compat": "--- DashScope via OpenAI-compatible endpoint ---",
    "dashscope-kimi": {
      "type": "chat",
      "adapter": "openai",
      "endpoint": "https://coding-intl.dashscope.aliyuncs.com/v1",
      "apiKey": "your-dashscope-api-key",
      "adapterModel": "kimi-k2.5",
      "capabilities": {
        "contextWindow": 256000,
        "maxOutputTokens": 98304,
        "vision": true,
        "structuredOutput": true,
        "streaming": true
      }
    },
    
    "_comment_disabled": "--- Disabled Model Example ---",
    "disabled-model": {
      "type": "chat",
      "adapter": "openai",
      "endpoint": "https://api.openai.com/v1",
      "apiKey": "your-api-key",
      "adapterModel": "gpt-4",
      "disabled": true,
      "capabilities": {
        "contextWindow": 128000,
        "vision": true,
        "streaming": true
      }
    }
  },
  
  "thinking": {
    "enabled": false,
    "stripTags": ["think", "thinking", "thought", "reasoning"],
    "orphanCloseAsSeparator": true,
    "maxThinkingContent": 8192
  },
  
  "routing": {
    "defaultChatModel": "llama-chat",
    "defaultEmbeddingModel": "llama-embed",
    "defaultImageModel": "gemini-image",
    "defaultAudioModel": "gemini-tts"
  },
  
  "compaction": {
    "enabled": true,
    "mode": "truncate",
    "minTokensToCompact": 2000,
    "preserveSystemPrompt": true,
    "preserveLastN": 4
  },
  
  "mediaProcessor": {
    "enabled": true,
    "endpoint": "http://localhost:3500"
  },
  
  "ws": {
    "localOnly": false,
    "whitelistIps": ["192.168.*"]
  },
  
  "tasks": {
    "_comment": "=== TASK-BASED QUERY SYSTEM ===",
    "_comment_note": "Tasks define semantic routing with preset parameters. Client request params override task defaults.",
    
    "query": {
      "model": "openai-chat",
      "description": "General query and conversation",
      "maxTokens": 4096,
      "temperature": 0.7
    },
    "inspect": {
      "model": "openai-chat",
      "description": "Code inspection and analysis",
      "maxTokens": 8192,
      "temperature": 0.4,
      "stripThinking": false
    },
    "synthesis": {
      "model": "gemini-flash",
      "description": "Content synthesis and summarization",
      "maxTokens": 2048,
      "temperature": 0.4,
      "stripThinking": true,
      "systemPrompt": "Summarize the following content concisely."
    },
    "analysis": {
      "model": "gemini-flash",
      "description": "Deep analysis and reasoning",
      "maxTokens": 8192,
      "temperature": 0.4,
      "stripThinking": false
    },
    "embed": {
      "model": "gemini-embedding",
      "description": "Text embedding generation"
    },
    "vision": {
      "model": "gemini-flash",
      "description": "Image understanding and visual analysis",
      "maxTokens": 4096,
      "temperature": 0.4
    },
    "image": {
      "model": "openai-image",
      "description": "Image generation from text prompts"
    },
    "tts": {
      "model": "openai-tts",
      "description": "Text-to-speech synthesis"
    }
  }
}
