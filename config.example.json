{
  "port": 3400,
  "host": "0.0.0.0",
  
  "models": {
    "lmstudio-chat": {
      "type": "chat",
      "adapter": "lmstudio",
      "endpoint": "http://localhost:12345",
      "adapterModel": "qwen/qwen2.5-9b",
      "capabilities": {
        "contextWindow": 30000,
        "vision": true,
        "structuredOutput": true,
        "streaming": true
      }
    },
    "lmstudio-embed": {
      "type": "embedding",
      "adapter": "lmstudio",
      "endpoint": "http://localhost:12345",
      "adapterModel": "text-embedding-nomic",
      "capabilities": {
        "contextWindow": 512,
        "dimensions": 768
      }
    },
    "ollama-chat": {
      "type": "chat",
      "adapter": "ollama",
      "endpoint": "http://localhost:11434",
      "adapterModel": "gemma3:12b",
      "capabilities": {
        "contextWindow": 8192,
        "vision": true,
        "structuredOutput": true,
        "streaming": true
      }
    },
    "ollama-embed": {
      "type": "embedding",
      "adapter": "ollama",
      "endpoint": "http://localhost:11434",
      "adapterModel": "nomic-embed-text",
      "capabilities": {
        "contextWindow": 512,
        "dimensions": 768
      }
    },
    "gemini-flash": {
      "type": "chat",
      "adapter": "gemini",
      "endpoint": "https://generativelanguage.googleapis.com/v1beta",
      "apiKey": "your-gemini-api-key",
      "adapterModel": "gemini-2.0-flash",
      "capabilities": {
        "contextWindow": 1000000,
        "vision": true,
        "structuredOutput": "json_schema",
        "streaming": true
      }
    },
    "gemini-embedding": {
      "type": "embedding",
      "adapter": "gemini",
      "endpoint": "https://generativelanguage.googleapis.com/v1beta",
      "apiKey": "your-gemini-api-key",
      "adapterModel": "embedding-001",
      "capabilities": {
        "contextWindow": 2048,
        "dimensions": 768
      }
    },
    "grok-chat": {
      "type": "chat",
      "adapter": "openai",
      "endpoint": "https://api.x.ai/v1",
      "apiKey": "your-grok-api-key",
      "adapterModel": "grok-2",
      "capabilities": {
        "contextWindow": 1000000,
        "vision": true,
        "structuredOutput": true,
        "streaming": true
      }
    },
    "openai-chat": {
      "type": "chat",
      "adapter": "openai",
      "endpoint": "https://api.openai.com/v1",
      "apiKey": "your-openai-api-key",
      "adapterModel": "gpt-4o",
      "capabilities": {
        "contextWindow": 128000,
        "vision": true,
        "structuredOutput": true,
        "streaming": true
      }
    },
    "openai-image": {
      "type": "image",
      "adapter": "openai",
      "endpoint": "https://api.openai.com/v1",
      "apiKey": "your-openai-api-key",
      "adapterModel": "dall-e-3",
      "capabilities": {
        "maxResolution": "1024x1024",
        "supportedFormats": ["png", "jpeg"]
      }
    },
    "openai-tts": {
      "type": "audio",
      "adapter": "openai",
      "endpoint": "https://api.openai.com/v1",
      "apiKey": "your-openai-api-key",
      "adapterModel": "tts-1",
      "capabilities": {
        "streaming": false
      }
    },
    "openai-responses": {
      "type": "chat",
      "adapter": "responses",
      "endpoint": "https://api.openai.com/v1",
      "apiKey": "your-openai-api-key",
      "adapterModel": "gpt-4o",
      "maxTokens": 4096,
      "capabilities": {
        "contextWindow": 128000,
        "vision": true,
        "streaming": true,
        "tools": true,
        "stateful": true
      }
    }
  },
  
  "thinking": {
    "enabled": false,
    "stripTags": ["think", "thinking", "thought", "reasoning"],
    "orphanCloseAsSeparator": true
  },
  
  "routing": {
    "defaultChatModel": "lmstudio-chat",
    "defaultEmbeddingModel": "lmstudio-embed"
  },
  
  "compaction": {
    "enabled": true,
    "mode": "truncate",
    "minTokensToCompact": 2000,
    "preserveSystemPrompt": true,
    "preserveLastN": 4
  }
}
